  // pages/utils/spoilers.js
  function initializeSpoilers() {
    const spoilerElements = document.querySelectorAll(".spoiler");
    if (spoilerElements.length > 0) {
      spoilerElements.forEach((element) => {
        element.addEventListener("click", () => {
          element.classList.toggle("tagged");
        });
        element.addEventListener("touchstart", (event) => {
          element.classList.toggle("tagged");
          event.preventDefault();
        });
      });
    }
  }

  // pages/elements/side.js
  var SideElement = class {
    constructor(elem) {
      this.elem = elem;
      this.handleSidebySideMobileView();
      this.handleImageSwitch();
      window.addEventListener("resize", () => {
        this.handleSidebySideMobileView();
      });
    }
    handleImageSwitch() {
      const smallSideLinks = this.elem.querySelectorAll(".small-side a");
      smallSideLinks.forEach((link) => {
        ["touchstart", "click", "mouseenter"].forEach((eventType) => {
          link.addEventListener(eventType, (event) => {
            this.handleImageSwitchEvent(event, link);
          });
        });
      });
    }
    handleImageSwitchEvent(event, link) {
      event.preventDefault();
      const largeLink = link.getAttribute("href");
      const sideElement = link.closest(".side-element");
      this.updateDisplayLink(sideElement, largeLink);
      this.updateMediumImage(link, sideElement);
    }
    updateDisplayLink(sideElement, largeLink) {
      const displayLink = sideElement.querySelector(".side-image-display a");
      if (displayLink) {
        displayLink.setAttribute("href", largeLink);
      }
      const sideImageLink = sideElement.querySelector(".side-image-link");
      if (sideImageLink) {
        sideImageLink.setAttribute("href", largeLink);
      }
    }
    updateMediumImage(link, sideElement) {
      const smallMedia = link.querySelector(".small-side-image");
      if (!smallMedia) return;
      const mediumContainer = sideElement.querySelector(".side-image-link");
      if (!mediumContainer) return;
      const clone = smallMedia.cloneNode(true);
      clone.classList.remove("small-side-image");
      clone.classList.add("medium-side-image");
      const currentMediumElement = sideElement.querySelector(".medium-side-image");
      if (!currentMediumElement) return;
      mediumContainer.replaceChild(clone, currentMediumElement);
      if (clone.tagName.toLowerCase() === "video") {
        if (typeof clone.load === "function") {
          clone.load();
        }
        clone.play().catch((e2) => console.warn("Could not play video:", e2));
      }
    }
    handleSidebySideMobileView() {
      if (window.innerWidth <= 770) {
        const smallImages = this.elem.querySelectorAll(".small-side-image");
        smallImages.forEach((image) => {
          const src = image.getAttribute("src");
          if (src) {
            image.setAttribute("src", src.replace("thumb160", "medium640"));
          }
        });
      }
    }
  };
  function initializeSideElements(selector) {
    const elements = document.querySelectorAll(selector);
    elements.forEach((element) => new SideElement(element));
  }

  // pages/elements/markdown.js
  var MarkdownElement = class {
    constructor(element) {
      this.element = element;
      this.processTemplates();
    }
    processTemplates() {
      const username = document.querySelector("#account .name")?.dataset.username;
      this.element.querySelectorAll(".markdown-html").forEach((markdownHtml) => {
        const html = markdownHtml.innerHTML.replace(
          /%7B%7B(.+?)%7D%7D/g,
          "{{$1}}"
        );
        markdownHtml.innerHTML = this.renderTemplate(html, { username });
      });
    }
    renderTemplate(template, data) {
      return template.replace(/\{\{([^}]+)\}\}/g, (match, key2) => {
        const trimmedKey = key2.trim();
        return data[trimmedKey] !== void 0 ? data[trimmedKey] : "";
      });
    }
  };
  function initializeMarkdownElements(selector) {
    const elements = document.querySelectorAll(selector);
    elements.forEach((element) => new MarkdownElement(element));
  }

  // pages/elements/button.js
  var ButtonElement = class {
    constructor(element) {
      this.element = element;
      this.cacheTimeout = 60 * 60 * 1e3;
      if (!element) {
        return;
      }
      this.processGithubReleaseLinks();
    }
    async processGithubReleaseLinks() {
      const releaseAttribute = this.element.dataset.githubRelease;
      if (!releaseAttribute) return;
      try {
        const release = JSON.parse(releaseAttribute);
        if (release && release.filename) {
          try {
            const data = await this.rebuildApiLinks(release);
            this.findAndReplaceLink(release, data);
          } catch (error3) {
            console.error("Error fetching GitHub release data:", error3);
          }
        }
      } catch (e2) {
        console.error("Error parsing GitHub release data:", e2);
      }
    }
    async rebuildApiLinks(release) {
      const apiUrl = `https://api.github.com/repos/${release.owner}/${release.repository}/releases/latest`;
      const cacheKey = `cache-learn-${this.element.id}`;
      const cached = sessionStorage.getItem(cacheKey);
      if (cached) {
        try {
          const parsedCache = JSON.parse(cached);
          if (parsedCache.timestamp && Date.now() < parsedCache.timestamp) {
            return parsedCache.data;
          }
        } catch (e2) {
          console.warn("Error parsing cached data:", e2);
        }
      }
      try {
        const response = await fetch(apiUrl);
        if (!response.ok) {
          throw new Error(`GitHub API request failed: ${response.status}`);
        }
        const data = await response.json();
        sessionStorage.setItem(
          cacheKey,
          JSON.stringify({
            timestamp: Date.now() + this.cacheTimeout,
            data
          })
        );
        return data;
      } catch (error3) {
        console.error("Failed to fetch GitHub release data:", error3);
        throw error3;
      }
    }
    findAndReplaceLink(release, githubResponse) {
      let filename = release.filename;
      filename = filename.split("*").map((value) => {
        return "(" + value + "){1}";
      }).join("[\\S]+");
      filename = "^" + filename + "$";
      const regexp = new RegExp(filename, "g");
      githubResponse.assets.forEach((asset) => {
        if (asset.name.match(regexp)) {
          const link = this.element.querySelector("a");
          if (link) {
            link.setAttribute("href", asset.browser_download_url);
          }
        }
      });
    }
  };
  function initializeButtonElements(selector) {
    const elements = document.querySelectorAll(selector);
    elements.forEach((element) => new ButtonElement(element));
  }

  // pages/elements/code.js
  var CodeElement = class {
    constructor(element) {
      this.element = element;
