      $.ajax({
        url: "/users/wishlists/" + $(target).val() + "/add_product",
        accept: "application/json",
        cache: false,
        type: "POST",
        data: { product_id: $(target).data("productId") },
        error: function(jqXHR, textStatus, errorThrown) {
