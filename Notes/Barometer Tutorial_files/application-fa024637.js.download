    sendRemoveRequest(target) {
      var self2 = this;
      $.ajax({
        url: "/users/wishlists/" + $(target).val(),
        accept: "application/json",
        cache: false,
        type: "DELETE",
        xhrFields: {
          withCredentials: true
        },
        data: { product_id: $(target).data("productId") },
