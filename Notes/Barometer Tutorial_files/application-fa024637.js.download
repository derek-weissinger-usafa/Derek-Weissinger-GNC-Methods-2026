  // components/dropdown.js
  var Dropdown = class {
    constructor() {
      if ($(".dropdown").length) {
        this.overlay = new Overlay();
        this.addListeners();
      }
    }
    addListeners() {
      this.toggles().attr("aria-expanded", "false");
      this.toggles().on("click touchstart", (e2) => this.handleLabelClick(e2));
      $(document).off("click.dropdown touchstart.dropdown keydown.dropdown");
      $(document).on("click.dropdown touchstart.dropdown", (e2) => this.handleClick(e2));
      $(document).on("keydown.dropdown", (e2) => this.handleKeydown(e2));
    }
    toggles($scope) {
      return ($scope || $(document)).find(".dropdown-label, .dropdown-icon");
    }
    closeDropdowns() {
      if ($(".dropdown").hasClass("active")) {
        $(".dropdown").removeClass("active");
        $(".dropdown").find(".dropdown-content").attr("tabindex", "-1");
        this.toggles().attr("aria-expanded", "false");
        this.overlay.close();
      }
    }
    handleLabelClick(event) {
      event.preventDefault();
      var $parent = $(event.target).closest(".dropdown");
      var active = !$parent.hasClass("active");
      this.closeDropdowns();
      if (active) {
        $parent.addClass("active");
        $parent.find(".dropdown-content").attr("tabindex", "0");
        this.toggles($parent).attr("aria-expanded", "true");
        if ($parent.hasClass("with-overlay")) {
          this.overlay.open();
        }
      }
    }
    handleClick(event) {
      if (!$(event.target).parents(".dropdown").length) {
        this.closeDropdowns();
      }
    }
    handleKeydown(event) {
      if (event.key === "Escape") {
        var $toggle = this.toggles($(".dropdown.active")).first();
        this.closeDropdowns();
        $toggle.trigger("focus");
      }
    }
  };

  // components/video_controller.js
  var VideoController = class {
    constructor() {
      this.observer = new IntersectionObserver(async (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            this.loadVideo(entry.target);
            if (entry.target.paused) {
              await this.playVideo(entry.target);
            }
          } else {
            if (!entry.target.paused) {
              entry.target.pause();
            }
          }
        }
      }, {});
      document.addEventListener(
        "turbo:load",
        (evt) => this.initializePlayback(evt)
      );
      document.addEventListener(
        "algolia-search",
        (evt) => this.initializePlayback(evt)
      );
      document.addEventListener(
        "turbo:before-cache",
        (evt) => this.stopVideos(evt)
      );
      document.addEventListener(
        "visibilitychange",
        (evt) => this.onVisibilityChange(evt)
      );
    }
    onVisibilityChange() {
      const videos = document.querySelectorAll("video");
      for (const video of videos) {
        if (document.hidden) {
          if (!video.paused) {
            video.pause();
          }
          this.observer.unobserve(video);
        } else {
          this.observer.observe(video);
        }
      }
    }
    loadVideo(video) {
      if (video.classList.contains("loaded")) return;
      let needsLoad = false;
      for (var source in video.children) {
        var videoSource = video.children[source];
        if (typeof videoSource.tagName === "string" && videoSource.tagName === "SOURCE") {
          if (videoSource.dataset.src && !videoSource.src) {
            videoSource.src = videoSource.dataset.src;
            needsLoad = true;
          }
        }
      }
      if (needsLoad) {
        video.load();
      }
      video.classList.add("loaded");
    }
    async playVideo(video) {
      try {
        if (video.readyState >= HTMLMediaElement.HAVE_CURRENT_DATA) {
          await video.play();
        } else {
          video.addEventListener(
            "canplay",
            async () => {
              try {
                await video.play();
              } catch (error3) {
                console.error("Error playing video after canplay event:", error3);
              }
            },
            { once: true }
          );
        }
      } catch (error3) {
        console.error("Error playing video:", error3);
      }
    }
    initializePlayback() {
      const videos = document.querySelectorAll("video");
      for (const video of videos) this.observer.observe(video);
    }
    stopVideos() {
      const videos = document.querySelectorAll("video");
      for (const video of videos) {
        if (!video.paused) {
          video.pause();
        }
        this.observer.unobserve(video);
      }
    }
  };

