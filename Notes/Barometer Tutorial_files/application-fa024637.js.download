    notifySuccess(target, text) {
      var $label = $("label[for='" + $(target).attr("id") + "']");
      var wishlistName = $label.text();
      $label.text(text);
      $label.addClass("green");
      $(target).prop("disabled", true);
      setTimeout(function() {
        $label.text(wishlistName);
        $label.removeClass("green");
        $(target).prop("disabled", false);
      }, 3e3);
    }
    notifyError(target) {
      var $label = $("label[for='" + $(target).attr("id") + "']");
      var wishlistName = $label.text();
      $label.text("ERROR");
      $label.addClass("red");
      $(target).prop("checked", function(i2, val) {
