        params.channel_id = $(".headline-video-group").data("cid");
      } else {
        params.playlist_id = $(".headline-video-group").data("playlist-id");
      }
      var reqURL = "/youtube_feed?" + $.param(params);
      var iframes = document.getElementsByClassName("latestVideoEmbed");
      $.ajax({
        dataType: "json",
        url: reqURL,
        success: function(data) {
          if (!data.items || data.items.length === 0) return;
          for (var i3 = 0, len = iframes.length; i3 < len; i3++) {
            var iframe = iframes[i3];
            var videoNumber = iframe.dataset.vnum ? Number(iframe.dataset.vnum) : 0;
            var item3 = data.items[videoNumber];
            if (!item3) continue;
            var id2 = new URL(item3.link).searchParams.get("v") || item3.guid.split(":").pop();
            iframe.setAttribute("src", "https://youtube.com/embed/" + id2 + "?controls=0&autoplay=0");
            iframe.setAttribute("title", item3.title);
