        data.forEach(function(wishlistItem) {
          var $checkbox = mustache_default.render(item_default, {
            productId,
            wishlistId: wishlistItem.id,
            wishlistName: wishlistItem.name
          });
          $(element).append($checkbox);
        });
      });
    }
    addListeners() {
      $(".add-to-wishlist").on("click", this.toggleDropdown.bind(this));
      $(document).on("click", ".wishlist", this.addToWishlist.bind(this));
      $("#create-wishlist").on("click", this.submitCreateForm.bind(this));
      document.querySelector(".show-create-wishlist-modal").addEventListener("click", this.showCreateWishlistModal.bind(this));
    }
    showCreateWishlistModal(event) {
      event.preventDefault();
      this.dialog.show();
    }
