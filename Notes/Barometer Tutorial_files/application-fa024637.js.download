        window.location = $("a:last-child", this).attr("href");
      }
    });
  });

  // pages/index.js
  var import_imagesloaded = __toESM(require_imagesloaded());

  // pages/cart.js
  var Cart = class {
    constructor() {
      this.setupProductLinks();
      this.cache_timeout = 2 * 60 * 1e3;
    }
    setupProductLinks() {
      this.setupIndividualProductButtons();
      this.initializeExistingCart();
    }
    setupIndividualProductButtons() {
      const productButtons = document.querySelectorAll(
        ".product-buy:not(.notify):not(.subscription)"
      );
      productButtons.forEach((button) => {
        new AddToCart(button, {
          wildCart,
          onAdded: (data) => {
            button.innerHTML = "Added!";
            setTimeout(() => {
              button.innerHTML = "Add to Cart";
            }, 2e3);
          }
        });
      });
    }
    initializeExistingCart() {
      if (api.get("cart_count")) {
        this.updateCartCount();
        this.fetchCartData();
      }
    }
    updateProductButtonStatus(data) {
      if (data && data.cart) {
        Object.keys(data.cart).forEach((key2) => {
          const element = document.getElementById(`${key2}-product`);
          if (element) {
            element.innerHTML = "Added!";
          }
        });
      }
    }
    fetchCartData() {
      const CACHE_KEY = "cache-learn-cart";
      const cachedData = this.getCartFromCache(CACHE_KEY);
      if (cachedData) {
        this.updateProductButtonStatus(cachedData);
        return;
      }
      this.fetchCartFromServer(CACHE_KEY);
    }
    getCartFromCache(cacheKey) {
      if (!localStorage) return null;
      try {
        const cached = JSON.parse(localStorage.getItem(cacheKey));
        if (cached && cached.timestamp && Date.now() < cached.timestamp) {
          return cached.data;
        }
      } catch (error3) {
        console.log("Error retrieving cart data from cache:", error3);
      }
      return null;
    }
    fetchCartFromServer(cacheKey) {
      wildCart.getToken().then((token) => {
        const body = new URLSearchParams({
          action: "get_cart",
          return_full_cart: 1,
          wildcartSecurityToken: token
        });
        return fetch(wildCart.wildCartUrl, {
          method: "POST",
          credentials: "include",
          headers: { "Content-Type": "application/x-www-form-urlencoded" },
          body,
          cache: "no-store"
        });
      }).then((response) => {
        if (!response.ok) {
          throw new Error(
            `Network response error: ${response.status} ${response.statusText}`
          );
        }
        return response.json();
      }).then((data) => {
        this.cacheCartData(cacheKey, data);
        this.updateProductButtonStatus(data);
        this.updateCartCount();
      }).catch((error3) => {
        console.log(`Error fetching cart: ${error3.message}`);
      });
    }
    cacheCartData(cacheKey, data) {
      if (!localStorage) return;
      try {
        const cacheEntry = {
          timestamp: Date.now() + this.cache_timeout,
          data
        };
        localStorage.setItem(cacheKey, JSON.stringify(cacheEntry));
      } catch (error3) {
        console.log("Error storing cart data in cache:", error3);
      }
    }
    updateCartCount() {
      const cartCount = api.get("cart_count");
      const text = `<i class='fa fa-shopping-cart'></i> ${cartCount}`;
      const cartLink = document.querySelector(".cart a");
      if (cartLink) {
        cartLink.innerHTML = text;
      }
    }
