      event.preventDefault();
      $(event.target).parent().find(".add-to-wishlist-content").toggleClass("closed");
    }
    addToWishlist(event) {
      if ($(event.target).prop("checked")) {
        this.sendAddRequest(event.target);
      } else {
        this.sendRemoveRequest(event.target);
