      this.setupManualCopyOverride();
    }
    setupCodeCopy() {
      const copyButtons = this.element.querySelectorAll(".code-copy-button");
      copyButtons.forEach((button) => {
        button.addEventListener("click", (event) => {
          event.preventDefault();
          this.handleCopyButtonClick(button);
          return false;
        });
      });
    }
    setupManualCopyOverride() {
      const container = this.element.querySelector(".code-preview-container");
      if (!container || !container.classList.contains("has-line-numbers")) return;
      container.addEventListener("copy", (event) => {
        const selection = document.getSelection();
        if (!selection.rangeCount) return;
        const range2 = selection.getRangeAt(0);
        const fragment = range2.cloneContents();
        const temp = document.createElement("div");
        temp.appendChild(fragment);
        const gutterCopy = temp.querySelector(".line-number-gutter");
        if (gutterCopy) gutterCopy.remove();
        const text = temp.textContent;
        if (!text) return;
        event.preventDefault();
        event.clipboardData.setData("text/plain", text);
      });
    }
    async handleCopyButtonClick(button) {
      const codeElement = button.closest(".code-element");
