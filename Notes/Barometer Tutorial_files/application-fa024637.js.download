      var description = $form.find("#wishlist_description").val();
      if (title === "") {
        alert("Please fill out form.");
      } else {
        this.sendCreateRequest(title, description);
      }
    }
    sendCreateRequest(title, description) {
      var self2 = this;
      $.ajax({
        url: "/users/wishlists/",
        accept: "application/json",
        cache: false,
        type: "POST",
        data: { title, description },
        error: function(jqXHR, textStatus, errorThrown) {
          console.log(
            " :( " + textStatus.toUpperCase() + " -- for ajaxAdd() : jqXHR.statusText = " + jqXHR.statusText + ", textStatus = " + textStatus
