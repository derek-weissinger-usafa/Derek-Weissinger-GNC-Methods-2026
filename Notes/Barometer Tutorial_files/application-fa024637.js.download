      var $nav = $(".sticky-nav");
      var nav_top = $nav.offset().top;
      $nav.before('<div class="nav-bar-placeholder">&nbsp</div>');
      var $placeholder = $(".nav-bar-placeholder");
      $placeholder.height(0);
      $(window).on("scroll", function() {
        var window_top = $(window).scrollTop();
        if (window_top > nav_top) {
          $nav.css({ position: "fixed", top: "0px", left: "0", right: "0" });
          $placeholder.height($nav.height() + 20);
        } else {
          $nav.css("position", "static");
          $placeholder.height(0);
        }
      });
    }
    if (window.devicePixelRatio >= 1.2) {
      var elems = document.getElementsByTagName("*");
      for (var i2 = 0; i2 < elems.length; i2++) {
        var attr = elems[i2].getAttribute("data-2x");
        if (attr && elems[i2].tagName == "IMG") {
          elems[i2].src = attr;
        } else if (attr) {
          elems[i2].style.cssText += "background-image: url(" + attr + ")";
        }
      }
    }
